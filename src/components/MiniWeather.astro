---
import { PLACE_LATITUDE, PLACE_LONGITUDE } from "../consts";
const API_URL = `https://api.open-meteo.com/v1/forecast?latitude=${PLACE_LATITUDE}&longitude=${PLACE_LONGITUDE}&current=temperature_2m,weather_code,is_day&timezone=Europe%2FMadrid`;

type WeatherData = {
  current: {
    temperature_2m: number;
    weather_code: number;
    is_day: 0 | 1;
  };
};

function weatherIcon(code: number, isDay: boolean): string {
  if (code === 0) return isDay ? "☀️" : "🌙";
  if (code <= 2) return isDay ? "⛅" : "🌤️";
  if (code === 3) return "☁️";
  if (code <= 49) return "🌫️";
  if (code <= 69) return "🌧️";
  if (code <= 79) return "❄️";
  if (code <= 82) return "🌧️";
  if (code <= 99) return "⛈️";
  return "🌡️";
}

let weather: WeatherData | null = null;

try {
  const res = await fetch(API_URL);
  if (res.ok) weather = await res.json();
} catch {}

const isDay = weather ? weather.current.is_day === 1 : true;
const icon = weather ? weatherIcon(weather.current.weather_code, isDay) : null;
const temp = weather ? `${weather.current.temperature_2m}°C` : null;
---

{
  weather && (
    <a
      href="/directo"
      class="weather-chip"
      aria-label={`Tiempo en Ciñera: ${temp}. Ver cámara en directo.`}
    >
      <span class="weather-icon">{icon}</span>
      <span class="weather-temp">{temp}</span>
    </a>
  )
}

<style>
  .weather-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    height: 32px;
    padding: 0 0.65rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, currentColor 15%, transparent);
    background: color-mix(in srgb, currentColor 6%, transparent);
    color: inherit;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    white-space: nowrap;
    transition:
      background 0.15s,
      border-color 0.15s;
  }

  .weather-chip:hover {
    background: color-mix(in srgb, currentColor 12%, transparent);
    border-color: color-mix(in srgb, currentColor 25%, transparent);
  }

  .weather-icon {
    font-size: 0.95rem;
    line-height: 1;
  }

  .weather-temp {
    line-height: 1;
  }
</style>
