---
---

<span id="mini-weather-root" class="mini-weather-host"></span>

<script>
  import { OPEN_METEO_MINI_URL, weatherIcon } from "../lib/openMeteoWeather";

  type MiniResponse = {
    current: {
      temperature_2m: number;
      weather_code: number;
      is_day: 0 | 1;
    };
  };

  function escapeAttr(s: string) {
    return s.replace(/&/g, "&amp;").replace(/"/g, "&quot;");
  }

  async function run() {
    const root = document.getElementById("mini-weather-root");
    if (!root) return;

    try {
      const res = await fetch(OPEN_METEO_MINI_URL);
      if (!res.ok) return;
      const data: MiniResponse = await res.json();
      const c = data.current;
      const isDay = c.is_day === 1;
      const icon = weatherIcon(c.weather_code, isDay);
      const temp = `${c.temperature_2m}°C`;
      const aria = escapeAttr(`Tiempo en Ciñera: ${temp}. Ver cámara en directo.`);

      root.innerHTML = `<a href="/directo" class="weather-chip" aria-label="${aria}"><span class="weather-icon">${icon}</span><span class="weather-temp">${c.temperature_2m}°C</span></a>`;
    } catch {
      /* sin chip si falla */
    }
  }

  run();
</script>

<style>
  .mini-weather-host :global(.weather-chip) {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    height: 32px;
    padding: 0 0.65rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, currentColor 15%, transparent);
    background: color-mix(in srgb, currentColor 6%, transparent);
    color: inherit;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    white-space: nowrap;
    transition:
      background 0.15s,
      border-color 0.15s;
  }

  .mini-weather-host :global(.weather-chip:hover) {
    background: color-mix(in srgb, currentColor 12%, transparent);
    border-color: color-mix(in srgb, currentColor 25%, transparent);
  }

  .mini-weather-host :global(.weather-icon) {
    font-size: 0.95rem;
    line-height: 1;
  }

  .mini-weather-host :global(.weather-temp) {
    line-height: 1;
  }
</style>
