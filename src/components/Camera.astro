<div id="camara-wrapper" class="camara-wrapper">
  <!-- Estado: cargando -->
  <div id="estado-cargando" class="camara-estado">
    <span class="spinner"></span>
    <p>Conectando con la cámara…</p>
  </div>

  <!-- Estado: error -->
  <div id="estado-error" class="camara-estado oculto">
    <p class="error-icono">📡</p>
    <p>La cámara no está disponible en este momento.</p>
    <button id="btn-reintentar">Reintentar</button>
  </div>

  <video
    id="camara-vivo"
    autoplay
    muted
    playsinline
    webkit-playsinline
    class="oculto"></video>

  <button
    type="button"
    id="btn-fullscreen"
    class="btn-fullscreen oculto"
    aria-label="Pantalla completa"
    aria-pressed="false"
  >
    <span class="icono-fs-expandir" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>
    </span>
    <span class="icono-fs-contraer oculto" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3v3a2 2 0 0 1-2 2H3m18 0h-3a2 2 0 0 1-2-2V3m0 18v-3a2 2 0 0 1 2-2h3M3 16h3a2 2 0 0 1 2 2v3"/></svg>
    </span>
  </button>
</div>
<details id="debug-panel" class="debug-panel oculto" open>
  <summary>Diagnóstico de reproducción</summary>
  <div id="debug-info" class="debug-info"></div>
  <pre id="debug-log" class="debug-log"></pre>
</details>

<script>
  import Hls from "hls.js";

  const video = document.getElementById("camara-vivo") as HTMLVideoElement;
  const wrapper = document.getElementById("camara-wrapper")!;
  const elCargando = document.getElementById("estado-cargando")!;
  const elError = document.getElementById("estado-error")!;
  const btnReintentar = document.getElementById("btn-reintentar")!;
  const btnFullscreen = document.getElementById("btn-fullscreen")!;
  const iconoExpandir = btnFullscreen.querySelector(".icono-fs-expandir")!;
  const iconoContraer = btnFullscreen.querySelector(".icono-fs-contraer")!;
  const url = "https://stream.faedodigital.com/cam/index.m3u8";

  function fullscreenElementActual(): Element | null {
    return (
      document.fullscreenElement ??
      (document as Document & { webkitFullscreenElement?: Element | null })
        .webkitFullscreenElement ??
      null
    );
  }

  function syncUiFullscreen() {
    const fs = fullscreenElementActual();
    const activo = fs === wrapper || fs === video;
    btnFullscreen.setAttribute("aria-pressed", activo ? "true" : "false");
    btnFullscreen.setAttribute(
      "aria-label",
      activo ? "Salir de pantalla completa" : "Pantalla completa",
    );
    iconoExpandir.classList.toggle("oculto", activo);
    iconoContraer.classList.toggle("oculto", !activo);
  }

  async function salirFullscreen() {
    const doc = document as Document & {
      webkitExitFullscreen?: () => void;
    };
    if (document.exitFullscreen) {
      await document.exitFullscreen().catch(() => {});
    } else if (doc.webkitExitFullscreen) {
      doc.webkitExitFullscreen();
    }
  }

  async function entrarFullscreen() {
    const w = wrapper as HTMLElement & {
      webkitRequestFullscreen?: () => void;
    };
    const v = video as HTMLVideoElement & {
      webkitRequestFullscreen?: () => void;
      webkitEnterFullscreen?: () => void;
    };

    const intentar = async (el: HTMLElement) => {
      if (el.requestFullscreen) {
        await el.requestFullscreen();
        return;
      }
      const webkit = (
        el as HTMLElement & { webkitRequestFullscreen?: () => void }
      ).webkitRequestFullscreen;
      if (webkit) {
        webkit.call(el);
        return;
      }
      throw new Error("sin fullscreen");
    };

    try {
      await intentar(wrapper);
    } catch {
      try {
        await intentar(video);
      } catch {
        if (v.webkitEnterFullscreen) {
          v.webkitEnterFullscreen();
        }
      }
    }
  }

  async function toggleFullscreen() {
    if (fullscreenElementActual()) {
      await salirFullscreen();
    } else {
      await entrarFullscreen();
    }
  }

  btnFullscreen.addEventListener("click", () => {
    toggleFullscreen().catch(() => {});
  });

  document.addEventListener("fullscreenchange", syncUiFullscreen);
  document.addEventListener(
    "webkitfullscreenchange",
    syncUiFullscreen as EventListener,
  );

  const MAX_REINTENTOS = 3;
  const DELAY_REINTENTO_MS = 4000;
  let reintentos = 0;
  let hls: Hls | null = null;
  let timeoutReintento: ReturnType<typeof setTimeout> | null = null;
  const MAX_LOGS = 30;
  const logs: string[] = [];
  const params = new URLSearchParams(window.location.search);
  const debugEnabled = params.get("debugCam") === "1";
  const debugLog = document.getElementById("debug-log");
  const debugInfo = document.getElementById("debug-info");
  const debugPanel = document.getElementById("debug-panel");

  if (debugPanel && debugEnabled) {
    debugPanel.classList.remove("oculto");
  }

  function logDebug(message: string) {
    if (!debugEnabled) return;
    const stamp = new Date().toLocaleTimeString("es-ES", {
      hour12: false,
      timeZone: "Europe/Madrid",
    });
    logs.unshift(`[${stamp}] ${message}`);
    if (logs.length > MAX_LOGS) logs.length = MAX_LOGS;
    if (debugLog) debugLog.textContent = logs.join("\n");
  }

  function renderInfo(extra = "") {
    if (!debugEnabled) return;
    if (!debugInfo) return;
    const mediaSourceOk = typeof window.MediaSource !== "undefined";
    const nativeHls = video.canPlayType("application/vnd.apple.mpegurl") || "no";
    const hlsJsSupport = Hls.isSupported();
    const lines = [
      `UA: ${navigator.userAgent}`,
      `MSE: ${mediaSourceOk ? "si" : "no"}`,
      `hls.js soportado: ${hlsJsSupport ? "si" : "no"}`,
      `HLS nativo: ${nativeHls}`,
      `stream: ${url}`,
      `reintentos: ${reintentos}/${MAX_REINTENTOS}`,
    ];
    if (extra) lines.push(extra);
    debugInfo.textContent = lines.join("\n");
  }

  function mostrar(estado: "cargando" | "error" | "video") {
    elCargando.classList.toggle("oculto", estado !== "cargando");
    elError.classList.toggle("oculto", estado !== "error");
    video.classList.toggle("oculto", estado !== "video");
    btnFullscreen.classList.toggle("oculto", estado !== "video");
    if (estado !== "video") {
      if (fullscreenElementActual()) {
        salirFullscreen().catch(() => {});
      }
      syncUiFullscreen();
    }
    logDebug(`estado UI -> ${estado}`);
    renderInfo(`estado_actual: ${estado}`);
  }

  function destruirHls() {
    if (hls) {
      logDebug("destruyendo instancia hls.js");
      hls.destroy();
      hls = null;
    }
    if (timeoutReintento) {
      clearTimeout(timeoutReintento);
      timeoutReintento = null;
    }
  }

  function onError() {
    logDebug("error fatal de reproducción");
    destruirHls();
    if (reintentos < MAX_REINTENTOS) {
      reintentos++;
      logDebug(
        `reintentando en ${DELAY_REINTENTO_MS}ms (${reintentos}/${MAX_REINTENTOS})`,
      );
      timeoutReintento = setTimeout(iniciarStream, DELAY_REINTENTO_MS);
    } else {
      logDebug("sin más reintentos, mostrando estado de error");
      mostrar("error");
    }
  }

  function iniciarStream() {
    destruirHls();
    mostrar("cargando");
    renderInfo();
    logDebug("iniciando stream");

    if (Hls.isSupported()) {
      logDebug("ruta hls.js (MSE)");
      hls = new Hls({
        lowLatencyMode: true,
        backBufferLength: 0,
        maxBufferLength: 10,
      });

      hls.loadSource(url);
      hls.attachMedia(video);

      hls.on(Hls.Events.MANIFEST_PARSED, () => {
        logDebug("manifest parseado correctamente");
        video.play().catch(() => {});
        mostrar("video");
        reintentos = 0;
      });

      hls.on(Hls.Events.ERROR, (_event, data) => {
        const details = `${data.type} / ${data.details} / fatal=${data.fatal ? "si" : "no"}`;
        logDebug(`hls.js error -> ${details}`);
        renderInfo(`ultimo_error: ${details}`);
        if (data.fatal) onError();
      });
    } else if (video.canPlayType("application/vnd.apple.mpegurl")) {
      // Safari / iOS — HLS nativo
      logDebug("ruta HLS nativo");
      video.src = url;
      video.load();

      video.addEventListener(
        "canplay",
        () => {
          logDebug("video canplay en HLS nativo");
          video.play().catch(() => {});
          mostrar("video");
          reintentos = 0;
        },
        { once: true },
      );

      video.addEventListener(
        "error",
        () => {
          const mediaError = video.error;
          const details = mediaError
            ? `code=${mediaError.code}, message=${mediaError.message || "sin mensaje"}`
            : "error nativo sin detalle";
          logDebug(`video error nativo -> ${details}`);
          renderInfo(`ultimo_error: ${details}`);
          onError();
        },
        { once: true },
      );
    } else {
      logDebug("navegador sin soporte HLS");
      mostrar("error");
    }
  }

  btnReintentar.addEventListener("click", () => {
    logDebug("click en reintentar");
    reintentos = 0;
    iniciarStream();
  });

  renderInfo("esperando inicio");
  iniciarStream();
</script>

<style>
  .camara-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--color-emerald-950);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .btn-fullscreen {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    border: 1px solid rgba(16, 185, 129, 0.35);
    border-radius: 0.375rem;
    background: rgba(2, 44, 34, 0.75);
    color: var(--color-emerald-200);
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }

  .btn-fullscreen:hover {
    background: rgba(6, 78, 59, 0.9);
    border-color: var(--color-emerald-600);
  }

  .btn-fullscreen:focus {
    outline: none;
  }

  .btn-fullscreen:focus-visible {
    outline: 2px solid var(--color-emerald-300);
    outline-offset: 2px;
  }

  .camara-estado {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: var(--color-emerald-400);
    font-size: 0.9rem;
  }

  .oculto {
    display: none;
  }

  .error-icono {
    font-size: 2rem;
  }

  #btn-reintentar {
    margin-top: 0.5rem;
    padding: 0.4rem 1.2rem;
    border: 1px solid var(--color-emerald-800);
    border-radius: 0.375rem;
    background: transparent;
    color: var(--color-emerald-200);
    cursor: pointer;
    font-size: 0.85rem;
    transition: background 0.2s;
  }

  #btn-reintentar:hover {
    background: var(--color-emerald-900);
  }

  .debug-panel {
    margin-top: 0.75rem;
    padding: 0.75rem;
    border: 1px solid var(--color-emerald-900);
    border-radius: 0.5rem;
    background: var(--color-emerald-950);
    color: var(--color-emerald-200);
    font-size: 0.8rem;
  }

  .debug-panel summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--color-emerald-300);
  }

  .debug-info {
    margin-top: 0.75rem;
    white-space: pre-wrap;
    line-height: 1.4;
  }

  .debug-log {
    margin-top: 0.75rem;
    max-height: 12rem;
    overflow: auto;
    border: 1px solid var(--color-emerald-900);
    border-radius: 0.375rem;
    padding: 0.5rem;
    background: #04110e;
    white-space: pre-wrap;
    word-break: break-word;
    line-height: 1.35;
  }

  /* Spinner */
  .spinner {
    width: 2rem;
    height: 2rem;
    border: 2px solid var(--color-emerald-800);
    border-top-color: var(--color-emerald-300);
    border-radius: 50%;
    animation: girar 0.8s linear infinite;
  }

  @keyframes girar {
    to {
      transform: rotate(360deg);
    }
  }
</style>
