<div class="camara-wrapper">
  <!-- Estado: cargando -->
  <div id="estado-cargando" class="camara-estado">
    <span class="spinner"></span>
    <p>Conectando con la cámara…</p>
  </div>

  <!-- Estado: error -->
  <div id="estado-error" class="camara-estado oculto">
    <p class="error-icono">📡</p>
    <p>La cámara no está disponible en este momento.</p>
    <button id="btn-reintentar">Reintentar</button>
  </div>

  <video
    id="camara-vivo"
    autoplay
    muted
    playsinline
    webkit-playsinline
    class="oculto"></video>
</div>
<details id="debug-panel" class="debug-panel oculto" open>
  <summary>Diagnóstico de reproducción</summary>
  <div id="debug-info" class="debug-info"></div>
  <pre id="debug-log" class="debug-log"></pre>
</details>

<script>
  import Hls from "hls.js";

  const video = document.getElementById("camara-vivo") as HTMLVideoElement;
  const elCargando = document.getElementById("estado-cargando")!;
  const elError = document.getElementById("estado-error")!;
  const btnReintentar = document.getElementById("btn-reintentar")!;
  const url = "https://stream.faedodigital.com/cam/index.m3u8";

  const MAX_REINTENTOS = 3;
  const DELAY_REINTENTO_MS = 4000;
  let reintentos = 0;
  let hls: Hls | null = null;
  let timeoutReintento: ReturnType<typeof setTimeout> | null = null;
  const MAX_LOGS = 30;
  const logs: string[] = [];
  const params = new URLSearchParams(window.location.search);
  const debugEnabled = params.get("debugCam") === "1";
  const debugLog = document.getElementById("debug-log");
  const debugInfo = document.getElementById("debug-info");
  const debugPanel = document.getElementById("debug-panel");

  if (debugPanel && debugEnabled) {
    debugPanel.classList.remove("oculto");
  }

  function logDebug(message: string) {
    if (!debugEnabled) return;
    const stamp = new Date().toLocaleTimeString("es-ES", {
      hour12: false,
      timeZone: "Europe/Madrid",
    });
    logs.unshift(`[${stamp}] ${message}`);
    if (logs.length > MAX_LOGS) logs.length = MAX_LOGS;
    if (debugLog) debugLog.textContent = logs.join("\n");
  }

  function renderInfo(extra = "") {
    if (!debugEnabled) return;
    if (!debugInfo) return;
    const mediaSourceOk = typeof window.MediaSource !== "undefined";
    const nativeHls = video.canPlayType("application/vnd.apple.mpegurl") || "no";
    const hlsJsSupport = Hls.isSupported();
    const lines = [
      `UA: ${navigator.userAgent}`,
      `MSE: ${mediaSourceOk ? "si" : "no"}`,
      `hls.js soportado: ${hlsJsSupport ? "si" : "no"}`,
      `HLS nativo: ${nativeHls}`,
      `stream: ${url}`,
      `reintentos: ${reintentos}/${MAX_REINTENTOS}`,
    ];
    if (extra) lines.push(extra);
    debugInfo.textContent = lines.join("\n");
  }

  function mostrar(estado: "cargando" | "error" | "video") {
    elCargando.classList.toggle("oculto", estado !== "cargando");
    elError.classList.toggle("oculto", estado !== "error");
    video.classList.toggle("oculto", estado !== "video");
    logDebug(`estado UI -> ${estado}`);
    renderInfo(`estado_actual: ${estado}`);
  }

  function destruirHls() {
    if (hls) {
      logDebug("destruyendo instancia hls.js");
      hls.destroy();
      hls = null;
    }
    if (timeoutReintento) {
      clearTimeout(timeoutReintento);
      timeoutReintento = null;
    }
  }

  function onError() {
    logDebug("error fatal de reproducción");
    destruirHls();
    if (reintentos < MAX_REINTENTOS) {
      reintentos++;
      logDebug(
        `reintentando en ${DELAY_REINTENTO_MS}ms (${reintentos}/${MAX_REINTENTOS})`,
      );
      timeoutReintento = setTimeout(iniciarStream, DELAY_REINTENTO_MS);
    } else {
      logDebug("sin más reintentos, mostrando estado de error");
      mostrar("error");
    }
  }

  function iniciarStream() {
    destruirHls();
    mostrar("cargando");
    renderInfo();
    logDebug("iniciando stream");

    if (Hls.isSupported()) {
      logDebug("ruta hls.js (MSE)");
      hls = new Hls({
        lowLatencyMode: true,
        backBufferLength: 0,
        maxBufferLength: 10,
      });

      hls.loadSource(url);
      hls.attachMedia(video);

      hls.on(Hls.Events.MANIFEST_PARSED, () => {
        logDebug("manifest parseado correctamente");
        video.play().catch(() => {});
        mostrar("video");
        reintentos = 0;
      });

      hls.on(Hls.Events.ERROR, (_event, data) => {
        const details = `${data.type} / ${data.details} / fatal=${data.fatal ? "si" : "no"}`;
        logDebug(`hls.js error -> ${details}`);
        renderInfo(`ultimo_error: ${details}`);
        if (data.fatal) onError();
      });
    } else if (video.canPlayType("application/vnd.apple.mpegurl")) {
      // Safari / iOS — HLS nativo
      logDebug("ruta HLS nativo");
      video.src = url;
      video.load();

      video.addEventListener(
        "canplay",
        () => {
          logDebug("video canplay en HLS nativo");
          video.play().catch(() => {});
          mostrar("video");
          reintentos = 0;
        },
        { once: true },
      );

      video.addEventListener(
        "error",
        () => {
          const mediaError = video.error;
          const details = mediaError
            ? `code=${mediaError.code}, message=${mediaError.message || "sin mensaje"}`
            : "error nativo sin detalle";
          logDebug(`video error nativo -> ${details}`);
          renderInfo(`ultimo_error: ${details}`);
          onError();
        },
        { once: true },
      );
    } else {
      logDebug("navegador sin soporte HLS");
      mostrar("error");
    }
  }

  btnReintentar.addEventListener("click", () => {
    logDebug("click en reintentar");
    reintentos = 0;
    iniciarStream();
  });

  renderInfo("esperando inicio");
  iniciarStream();
</script>

<style>
  .camara-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--color-emerald-950);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .camara-estado {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: var(--color-emerald-400);
    font-size: 0.9rem;
  }

  .oculto {
    display: none;
  }

  .error-icono {
    font-size: 2rem;
  }

  #btn-reintentar {
    margin-top: 0.5rem;
    padding: 0.4rem 1.2rem;
    border: 1px solid var(--color-emerald-800);
    border-radius: 0.375rem;
    background: transparent;
    color: var(--color-emerald-200);
    cursor: pointer;
    font-size: 0.85rem;
    transition: background 0.2s;
  }

  #btn-reintentar:hover {
    background: var(--color-emerald-900);
  }

  .debug-panel {
    margin-top: 0.75rem;
    padding: 0.75rem;
    border: 1px solid var(--color-emerald-900);
    border-radius: 0.5rem;
    background: var(--color-emerald-950);
    color: var(--color-emerald-200);
    font-size: 0.8rem;
  }

  .debug-panel summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--color-emerald-300);
  }

  .debug-info {
    margin-top: 0.75rem;
    white-space: pre-wrap;
    line-height: 1.4;
  }

  .debug-log {
    margin-top: 0.75rem;
    max-height: 12rem;
    overflow: auto;
    border: 1px solid var(--color-emerald-900);
    border-radius: 0.375rem;
    padding: 0.5rem;
    background: #04110e;
    white-space: pre-wrap;
    word-break: break-word;
    line-height: 1.35;
  }

  /* Spinner */
  .spinner {
    width: 2rem;
    height: 2rem;
    border: 2px solid var(--color-emerald-800);
    border-top-color: var(--color-emerald-300);
    border-radius: 50%;
    animation: girar 0.8s linear infinite;
  }

  @keyframes girar {
    to {
      transform: rotate(360deg);
    }
  }
</style>
