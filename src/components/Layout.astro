---
import {
  SITE_TITLE,
  SITE_DESCRIPTION,
  SITE_NAME,
  SITE_LOCALE,
  SITE_IMAGE,
  SITE_LOGO,
  PLACE_LATITUDE,
  PLACE_LONGITUDE,
  PLACE_ADDRESS_REGION,
  PLACE_ADDRESS_COUNTRY,
} from "../consts";
import GoogleSiteVerification from "./GoogleSiteVerification.astro";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import "../styles/globals.css";
import Guia from "./Guia.astro";
import MiniWeather from "./MiniWeather.astro";

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  url = undefined,
  image = undefined,
  type = "website",
} = Astro.props;

const canonicalURL = (
  url ?? new URL(Astro.url.pathname, Astro.site)
).toString();
const ogImage = image
  ? new URL(image, Astro.site).toString()
  : new URL(SITE_IMAGE, Astro.site).toString();

const siteUrl = Astro.site?.href.replace(/\/+$/, "") ?? "";
const logoUrl = Astro.site ? new URL(SITE_LOGO, Astro.site).href : SITE_LOGO;
const jsonLd =
  siteUrl &&
  JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "@id": `${siteUrl}/#website`,
        name: SITE_NAME,
        description: SITE_DESCRIPTION,
        url: `${siteUrl}/`,
        inLanguage: SITE_LOCALE,
        publisher: { "@id": `${siteUrl}/#organization` },
        about: { "@id": `${siteUrl}/#place` },
      },
      {
        "@type": ["City", "Place"],
        "@id": `${siteUrl}/#place`,
        name: SITE_NAME,
        description: SITE_DESCRIPTION,
        geo: {
          "@type": "GeoCoordinates",
          latitude: PLACE_LATITUDE,
          longitude: PLACE_LONGITUDE,
        },
        address: {
          "@type": "PostalAddress",
          addressLocality: SITE_NAME,
          addressRegion: PLACE_ADDRESS_REGION,
          addressCountry: PLACE_ADDRESS_COUNTRY,
        },
      },
      {
        "@type": "Organization",
        "@id": `${siteUrl}/#organization`,
        name: SITE_NAME,
        url: `${siteUrl}/`,
        logo: logoUrl,
      },
    ],
  });

const navItems: { href: string; label: string }[] = [
  { href: "/historia", label: "Historia" },
  { href: "/directo", label: "Directo" },
  { href: "/memoria", label: "Memoria" },
];
---

<!doctype html>
<html lang={SITE_LOCALE}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#349981" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang={SITE_LOCALE} href={canonicalURL} />
    <meta name="description" content={description} />
    <meta name="keywords" content="Ciñera sólo hay una." />
    <title>{title}</title>

    <!-- Open Graph / Facebook -->
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={SITE_LOCALE} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" href="/bandera.webp" type="image/webp" />
    <link rel="apple-touch-icon" href="/bandera.webp" />
    <meta name="apple-mobile-web-app-title" content="Faedo" />
    <link rel="manifest" href="/site.webmanifest" />

    <Font cssVariable="--font-figtree" preload />
    <Font cssVariable="--font-fraunces" preload />
    {
      jsonLd && (
        <script type="application/ld+json" set:html={jsonLd} />
      )
    }
    <slot name="head" />
    <GoogleSiteVerification />
    <ClientRouter />
    <script
      defer
      src="https://umami.faedodigital.com/script.js"
      data-website-id="08672708-577d-4cc5-a14f-fc2d89400616"
    ></script>
  </head>
  <body class="min-h-screen flex flex-col">
    <a class="skip-link" href="#contenido">Saltar al contenido</a>
    <header
      class="border-b border-gray-300 sticky top-0 bg-white/80 backdrop-blur-sm z-50"
      transition:persist
    >
      <nav
        class="container flex items-center justify-between"
        aria-label="Principal"
      >
        <a
          href="/"
          class="font-fraunces text-xl text-primary-700 no-underline inline-flex items-center gap-2"
        >
          <img
            src="/bandera.webp"
            alt="Escudo de Ciñera"
            width="50"
            height="50"
            class="shrink-0 object-contain"
            decoding="async"
          />
          {SITE_NAME}
        </a>

        {
          navItems.length > 0 && (
            
              <div class="flex items-center gap-2">
                <ul class="hidden md:flex font-fraunces text-prose-heading">
                  {navItems.map((item) => (
                    <li>
                      <a class="px-2 py-6 inline-block no-underline hover:opacity-90" href={item.href}>
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ul>
                <MiniWeather />
              

              <button
                id="menu-toggle"
                class="md:hidden my-4 p-2 text-prose-heading hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-primary-400 rounded"
                aria-label="Abrir menú"
                aria-expanded="false"
              >
                <svg
                  class="w-6 h-6"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 6h16M4 12h16M4 18h16"
                  />
                </svg>
              </button>
            </div>
            
          )
        }
      </nav>

      {
        navItems.length > 0 && (
          <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100">
            <ul class="container font-fraunces py-4 flex flex-col gap-3 text-center text-prose-heading">
              {navItems.map((item, index) => (
                <li>
                  <a
                    href={item.href}
                    class={`block py-2 no-underline hover:opacity-90 ${index < navItems.length - 1 ? "border-b border-gray-100" : ""}`}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </header>

    {
      navItems.length > 0 && (
        <script>
          const menuToggle = document.getElementById("menu-toggle");
          const mobileMenu = document.getElementById("mobile-menu");

          menuToggle?.addEventListener("click", () => {
            const isOpen = mobileMenu?.classList.toggle("hidden");
            menuToggle.setAttribute("aria-expanded", isOpen ? "false" : "true");
          });

          mobileMenu?.querySelectorAll("a").forEach((link) => {
            link.addEventListener("click", () => {
              mobileMenu.classList.add("hidden");
              menuToggle?.setAttribute("aria-expanded", "false");
            });
          });

          window.addEventListener("resize", () => {
            if (window.innerWidth >= 768) {
              mobileMenu?.classList.add("hidden");
              menuToggle?.setAttribute("aria-expanded", "false");
            }
          });
        </script>
      )
    }
    <main class="flex-1">
      <slot />
    </main>

    <Guia />

    <footer class="border-t border-gray-100" transition:persist>
      <div
        class="container py-8 text-sm flex flex-col gap-2 md:flex-row md:items-center md:justify-between"
      >
        <p class="text-center md:text-left">
          &copy; {new Date().getFullYear()}
          {SITE_NAME} · Proyecto informativo sin ánimo de lucro.
        </p>
        {
          navItems.length > 0 && (
            <nav aria-label="Secundario">
              <ul class="md:flex md:gap-4 font-fraunces text-center">
                {navItems.map((item) => (
                  <li>
                    <a
                      class="text-lg py-2 inline-block"
                      href={item.href}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          )
        }
      </div>
      <p class="text-center text-sm">
        Sitio web creado por <a
          href="https://faedodigital.com"
          target="_blank"
          rel="noopener noreferrer">Faedo Digital</a
        >
      </p>
    </footer>
  </body>
</html>
