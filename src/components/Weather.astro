---

<div
  id="weather-root"
  class="mx-auto rounded-xl border border-emerald-800 bg-emerald-900 p-4 shadow-sm max-w-sm"
>
  <p class="text-sm text-emerald-400 animate-pulse">Cargando el tiempo…</p>
</div>

<script>
  import {
    OPEN_METEO_CARD_URL,
    escapeHtml,
    weatherLabel,
    type OpenMeteoForecastResponse,
  } from "../lib/openMeteoWeather";

  function formatNow() {
    return new Date().toLocaleString("es-ES", {
      weekday: "long",
      day: "numeric",
      month: "long",
      hour: "2-digit",
      minute: "2-digit",
      timeZone: "Europe/Madrid",
    });
  }

  async function run() {
    const root = document.getElementById("weather-root");
    if (!root) return;

    try {
      const res = await fetch(OPEN_METEO_CARD_URL);
      if (!res.ok) throw new Error("bad status");
      const data: OpenMeteoForecastResponse = await res.json();
      const c = data.current;
      const isDay = c.is_day === 1;
      const { label, icon } = weatherLabel(c.weather_code, isDay);
      const now = formatNow();

      const headline = escapeHtml(`Ciñera · ${now}`);
      const labelEsc = escapeHtml(label);

      root.innerHTML = `
        <p class="text-xs font-medium uppercase tracking-wide text-emerald-500">${headline}</p>
        <div class="mt-3 flex items-center justify-between">
          <div class="flex items-end gap-3">
            <span class="text-5xl font-semibold text-emerald-100 leading-none">${c.temperature_2m}°C</span>
            <span class="text-2xl leading-none mb-0.5" aria-hidden="true">${icon}</span>
          </div>
          <span class="text-sm text-emerald-400">${labelEsc}</span>
        </div>
        <dl class="mt-4 grid grid-cols-3 gap-2 border-t border-emerald-800 pt-3">
          <div>
            <dt class="text-xs text-emerald-500">Humedad</dt>
            <dd class="mt-0.5 text-sm font-medium text-emerald-300">${c.relative_humidity_2m}%</dd>
          </div>
          <div>
            <dt class="text-xs text-emerald-500">Viento</dt>
            <dd class="mt-0.5 text-sm font-medium text-emerald-300">${c.wind_speed_10m} m/s</dd>
          </div>
          <div>
            <dt class="text-xs text-emerald-500">Precipitación</dt>
            <dd class="mt-0.5 text-sm font-medium text-emerald-300">${c.precipitation} mm</dd>
          </div>
        </dl>`;
    } catch {
      root.innerHTML =
        '<p class="text-sm text-emerald-400">No se pudo cargar el tiempo.</p>';
    }
  }

  run();
</script>
